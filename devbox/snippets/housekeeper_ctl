#!/usr/bin/env bash

# Default values
TIME=1800
SOCK=/tmp/housekeeper_ctl.sock
CONTROL_FILE=/tmp/housekeeper_ctl
# Require explicit command; do NOT default to pause
CMD=""   # pause|enable|disable|auto|monitor|sleep
UI="ansi"
SLEEP=""

print_help() {
  cat <<EOF
housekeeper_ctl — control commands for housekeeper

Usage:
  $(basename "$0") <command> [args] [OPTIONS]
  $(basename "$0") enable [OPTIONS]
  $(basename "$0") disable [OPTIONS]
  $(basename "$0") auto [OPTIONS]
  $(basename "$0") monitor [--ui ansi|line] [OPTIONS]
  $(basename "$0") sleep [MILLISECONDS] [OPTIONS]

  Commands:
  pause [SECONDS]   Pause workers for SECONDS (default: $TIME)
  enable            Enable workers immediately
  disable           Disable workers immediately
  auto              Switch to auto mode (status controller)
  monitor           Subscribe and display live status
  sleep [MILLISECONDS] Set worker sleep interval after each forward (0-60000ms)

Options:
  -s, --socket PATH        Unix socket path (default: $SOCK)
  -f, --file PATH          Control file for 'pause' fallback (default: $CONTROL_FILE)
      --control-file PATH  Same as --file
  -u, --ui MODE            UI for monitor: ansi|line (default: $UI)
  -h, --help           Show this help and exit

Examples:
  $(basename "$0") pause 600 -s /tmp/keep.sock
  $(basename "$0") enable
  $(basename "$0") disable
EOF
}

# Parse args: command + options
while [[ $# -gt 0 ]]; do
  case "$1" in
    help|-h|--help)
      print_help; exit 0 ;;
    enable|disable|pause|auto|monitor|sleep)
      CMD="$1"; shift
      # optional SECONDS after 'pause'
      if [[ "$CMD" == "pause" && $# -gt 0 && "$1" =~ ^[0-9]+$ ]]; then TIME="$1"; shift; fi
      # optional MILLISECONDS after 'sleep'
      if [[ "$CMD" == "sleep" && $# -gt 0 ]]; then SLEEP="$1"; shift; fi ;;
    -s|--socket)
      if [[ -n "$2" ]]; then SOCK="$2"; shift 2; else echo "Error: -s/--socket requires PATH" >&2; exit 1; fi ;;
    -f|--file|--control-file)
      if [[ -n "$2" ]]; then CONTROL_FILE="$2"; shift 2; else echo "Error: --file/--control-file requires PATH" >&2; exit 1; fi ;;
    -u|--ui)
      if [[ -n "$2" ]]; then UI="$2"; shift 2; else echo "Error: -u/--ui requires MODE" >&2; exit 1; fi ;;
    --) shift; break ;;
    *)
      echo "Unknown option or misplaced argument: $1" >&2; echo; print_help; exit 1 ;;
  esac
done

# Ensure a command is provided
if [[ -z "$CMD" ]]; then
  echo "ERROR: Invalid arguments, must specify command (pause|enable|disable|auto|monitor|sleep)" >&2
  echo
  print_help
  exit 1
fi

# Validate for pause
if [[ "$CMD" == "pause" ]] && ! [[ "$TIME" =~ ^[0-9]+$ ]]; then echo "Error: TIME must be a non-negative integer (got: $TIME)" >&2; exit 1; fi

# Send via socket helper
send_sock() {
  local payload="$1"
  if [[ -S "$SOCK" ]]; then
    if command -v python3 >/dev/null 2>&1; then PYTHON=python3; elif command -v python >/dev/null 2>&1; then PYTHON=python; else PYTHON=""; fi
    if [[ -n "$PYTHON" ]]; then
      "$PYTHON" - "$SOCK" "$payload" <<'PY'
import socket, sys
sock_path, payload = sys.argv[1], sys.argv[2]
try:
    s = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
    s.connect(sock_path)
    s.send(payload.encode())
    s.close()
    sys.exit(0)
except Exception:
    sys.exit(1)
PY
      return $?
    fi
  fi
  return 2
}

case "$CMD" in
  enable)
    if send_sock "enable"; then echo "INFO: enable via $SOCK"; exit 0; else echo "ERROR: socket not available for enable ($SOCK)" >&2; exit 1; fi ;;
  disable)
    if send_sock "disable"; then echo "INFO: disable via $SOCK"; exit 0; else echo "ERROR: socket not available for disable ($SOCK)" >&2; exit 1; fi ;;
  auto)
    if send_sock "auto"; then echo "INFO: auto via $SOCK"; exit 0; else echo "ERROR: socket not available for auto ($SOCK)" >&2; exit 1; fi ;;
  monitor)
    PUB="${SOCK}.pub"
    if [[ ! -S "$PUB" ]]; then echo "INFO: publish socket not found, please update server for monitor"; exit 1; fi
    # Python monitor subscriber (ansi/line)
    if command -v python3 >/dev/null 2>&1; then PYTHON=python3; elif command -v python >/dev/null 2>&1; then PYTHON=python; else echo "Error: python not found" >&2; exit 1; fi
    # Resolve real script directory (follow symlinks when possible)
    if command -v readlink >/dev/null 2>&1; then
      SCRIPT_PATH=$(readlink -f "$0" 2>/dev/null || echo "$0")
    else
      SCRIPT_PATH="$0"
    fi
    BASE_DIR=$(cd "$(dirname "$SCRIPT_PATH")" && pwd)
    "$PYTHON" - "$PUB" "$UI" "$BASE_DIR" <<'PY'
import os, sys, socket, json, time, tempfile, signal, importlib.util
pub_path, ui, base_dir = sys.argv[1], (sys.argv[2] if len(sys.argv)>2 else 'ansi'), (sys.argv[3] if len(sys.argv)>3 else None)
ui = ui.lower().strip()

# Try path-based loader first to support single-file 'housekeeper' without .py
render_line = None
render_ansi = None
_tried_paths = []

def load_renderers_from_path(path):
    _tried_paths.append(path)
    try:
        spec = importlib.util.spec_from_file_location('housekeeper_renderers', path)
        if not spec or not spec.loader:
            return None, None
        mod = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)  # type: ignore
        return getattr(mod, 'render_line', None), getattr(mod, 'render_ansi', None)
    except Exception:
        return None, None

# Try load from file paths first (supports extensionless file)
if base_dir:
    candidate = os.path.join(base_dir, 'housekeeper.py')
    if os.path.isfile(candidate):
        rl, ra = load_renderers_from_path(candidate)
        if rl and ra:
            render_line, render_ansi = rl, ra

# As a last resort, try module import (package layout)
if (render_line is None or render_ansi is None) and base_dir and base_dir not in sys.path:
    sys.path.insert(0, base_dir)
if render_line is None or render_ansi is None:
    try:
        from housekeeper import render_line as _rl, render_ansi as _ra
        render_line, render_ansi = _rl, _ra
    except Exception as e:
        tried = ", ".join(_tried_paths) or '(no paths)'
        sys.stderr.write(f'WARN: failed to load renderers; tried paths: {tried}; module error: {e}\n')
tmpd = tempfile.mkdtemp(prefix='hk_', dir='/tmp')
client = os.path.join(tmpd, 'm.sock')
sock = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
try:
    prev = os.umask(0o077)
    sock.bind(client)
finally:
    os.umask(prev)
try:
    os.chmod(client, 0o600)
except Exception:
    pass
sock.settimeout(1.0)

def cleanup():
    try:
        sock.sendto(json.dumps({'op':'unsub'}).encode(), pub_path)
    except Exception:
        pass
    try: sock.close()
    except Exception: pass
    try: os.unlink(client)
    except Exception: pass
    try: os.rmdir(tmpd)
    except Exception: pass

stop=False
signal.signal(signal.SIGINT, lambda *a: (_ for _ in ()).throw(KeyboardInterrupt()))
signal.signal(signal.SIGTERM, lambda *a: (_ for _ in ()).throw(KeyboardInterrupt()))

try:
    # subscribe
    sock.sendto(json.dumps({'op':'sub','v':1}).encode(), pub_path)
    last_hb=time.monotonic()
    last_sub=last_hb
    last_recv=time.monotonic()
    while True:
        try:
            data,_ = sock.recvfrom(65536)
        except socket.timeout:
            data=None
        if data:
            try:
                snap=json.loads(data.decode('utf-8'))
            except Exception:
                snap=None
            if snap:
                last_recv=time.monotonic()
                # Render using shared functions (they return strings)
                if ui=='ansi' and callable(render_ansi):
                    screen = render_ansi(snap)
                    sys.stdout.write(screen)
                    sys.stdout.flush()
                else:
                    if callable(render_line):
                        line = render_line(snap)
                    else:
                        ts=time.strftime('[%H:%M:%S]')
                        line = ts + ' ' + ', '.join([f"Mode={snap.get('mode')}", f"Keeping={snap.get('keeping')}", f"Decision={snap.get('decision')}"])
                    sys.stdout.write('\r'+line)
                    sys.stdout.flush()
        # heartbeat
        now=time.monotonic()
        if now-last_hb>1.0:
            try: sock.sendto(json.dumps({'op':'hb'}).encode(), pub_path)
            except Exception: pass
            last_hb=now
        # auto re-subscribe if no packets for a while (server may have restarted)
        if now - last_recv > 2.0 and now - last_sub > 1.0:
            try:
                sock.sendto(json.dumps({'op':'sub','v':1}).encode(), pub_path)
            except Exception:
                pass
            last_sub = now
        time.sleep(0.1)
except KeyboardInterrupt:
    pass
finally:
    cleanup()
PY
    exit 0 ;;
  pause)
    if send_sock "pause $TIME"; then echo "INFO: pause ${TIME}s via $SOCK"; exit 0; fi
    # Fallback to file only for pause
    echo "$TIME" > "$CONTROL_FILE"
    echo "INFO: pause ${TIME}s via $CONTROL_FILE"; exit 0 ;;
  sleep)
    if [[ -z "$SLEEP" ]]; then echo "ERROR: sleep need milliseconds (allow float)" >&2; exit 1; fi
    if send_sock "sleep $SLEEP"; then echo "INFO: sleep ${SLEEP}ms via $SOCK"; exit 0; else echo "ERROR: socket not available for sleep ($SOCK)" >&2; exit 1; fi ;;
esac
