#!/usr/bin/env bash

set -euo pipefail

target="."
target_set=0
interval=1
alpha="0.30"
recursive=0
include_dirs=0
name_pattern=""
parallel=32
samples=0
total=0
ui="screen"
history_limit=1000

COLOR_RESET=$'\033[0m'
COLOR_BOLD=$'\033[1m'
COLOR_DIM=$'\033[2m'
COLOR_REVERSE=$'\033[7m'
COLOR_RED=$'\033[31m'
COLOR_GREEN=$'\033[32m'
COLOR_YELLOW=$'\033[33m'
COLOR_BLUE=$'\033[34m'
COLOR_MAGENTA=$'\033[35m'
COLOR_CYAN=$'\033[36m'
COLOR_BG_BLUE=$'\033[44m'
COLOR_WHITE=$'\033[37m'

usage() {
  local cmd
  cmd="$(basename "$0")"

  cat <<EOF
usage: ${cmd} [path] [options]

Continuously monitor file count under a directory and print growth/shrink speed.
The smoothed speed uses EMA: smooth = alpha * current + (1 - alpha) * previous.

options:
  -i, --interval SEC   Poll interval in seconds. Default: 1
  -a, --alpha VALUE    EMA smoothing alpha in (0, 1]. Lower is smoother. Default: 0.30
  -n, --name PATTERN   Count only files whose basename matches shell/find pattern, e.g. '*.jpg'
  --recursive          Count files recursively
  -p, --parallel N     Recursive count worker processes. Default: 32; use 0 to fallback to find
  --include-dirs       Count directories too in non-recursive mode
  --total N            Expected final file count; show progress and ETA when speed is positive
  --samples N          Stop after N printed samples.
  --append             Use stable append output instead of the default interactive screen UI
  --history N          Rows to keep in screen mode. Default: 1000
  -h, --help           Show this help message and exit

screen UI keys:
  h / ?                Show all screen UI keys
  Esc                  Close help panel only

examples:
  ${cmd} ./outputs
  ${cmd} ./outputs --interval 2 --alpha 0.2
  ${cmd} ./outputs --name '*.jsonl'
  ${cmd} ./outputs --include-dirs
  ${cmd} ./outputs --total 100000
  ${cmd} ./outputs --append
  ${cmd} ./outputs --recursive --samples 10
  ${cmd} ./outputs --recursive -p 0
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

count_files() {
  local count entry base

  if [[ "$recursive" -eq 1 ]]; then
    if [[ "$parallel" -gt 0 ]] && command -v python3 >/dev/null 2>&1; then
      python3 - "$target" "$name_pattern" "$parallel" <<'PY'
import fnmatch
import multiprocessing as mp
import os
import sys

target, name_pattern, parallel = sys.argv[1], sys.argv[2], int(sys.argv[3])
try:
    mp.set_start_method("fork")
except RuntimeError:
    pass

def worker(dir_queue, result_queue):
    count = 0
    while True:
        path = dir_queue.get()
        if path is None:
            dir_queue.task_done()
            break
        try:
            with os.scandir(path) as entries:
                for entry in entries:
                    try:
                        if entry.is_dir(follow_symlinks=False):
                            dir_queue.put(entry.path)
                        elif entry.is_file(follow_symlinks=False):
                            if not name_pattern or fnmatch.fnmatchcase(entry.name, name_pattern):
                                count += 1
                    except OSError:
                        pass
        except OSError:
            pass
        finally:
            dir_queue.task_done()
    result_queue.put(count)

dir_queue = mp.JoinableQueue()
result_queue = mp.Queue()
processes = [mp.Process(target=worker, args=(dir_queue, result_queue)) for _ in range(parallel)]
for process in processes:
    process.start()
dir_queue.put(target)
dir_queue.join()
for _ in processes:
    dir_queue.put(None)
dir_queue.join()
total = 0
for _ in processes:
    total += result_queue.get()
for process in processes:
    process.join()
print(total)
PY
      return
    fi
    if [[ -n "$name_pattern" ]]; then
      { find "$target" -type f -name "$name_pattern" -print 2>/dev/null || true; } | wc -l | tr -d '[:space:]'
    else
      { find "$target" -type f -print 2>/dev/null || true; } | wc -l | tr -d '[:space:]'
    fi
    return
  fi

  if [[ -z "$name_pattern" ]]; then
    if [[ "$include_dirs" -eq 1 ]]; then
      LC_ALL=C ls -1A "$target" 2>/dev/null | wc -l | tr -d '[:space:]'
    else
      LC_ALL=C ls -1Ap "$target" 2>/dev/null | awk 'substr($0, length($0), 1) != "/" { n++ } END { print n + 0 }'
    fi
    return
  fi

  count=0
  shopt -s nullglob dotglob
  for entry in "$target"/*; do
    if [[ "$include_dirs" -eq 1 ]]; then
      [[ -f "$entry" || -d "$entry" ]] || continue
    else
      [[ -f "$entry" ]] || continue
    fi
    if [[ -n "$name_pattern" ]]; then
      base="$(basename "$entry")"
      [[ "$base" == $name_pattern ]] || continue
    fi
    ((count += 1))
  done
  shopt -u nullglob dotglob
  printf '%s\n' "$count"
}

parse_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -i | --interval)
        [[ "$#" -ge 2 ]] || die "$1 requires a value"
        interval="$2"
        shift 2
        ;;
      -a | --alpha)
        [[ "$#" -ge 2 ]] || die "$1 requires a value"
        alpha="$2"
        shift 2
        ;;
      -n | --name)
        [[ "$#" -ge 2 ]] || die "$1 requires a value"
        name_pattern="$2"
        shift 2
        ;;
      -p | --parallel)
        [[ "$#" -ge 2 ]] || die "$1 requires a value"
        parallel="$2"
        shift 2
        ;;
      --recursive)
        recursive=1
        shift
        ;;
      --include-dirs)
        include_dirs=1
        shift
        ;;
      --total)
        [[ "$#" -ge 2 ]] || die "$1 requires a value"
        total="$2"
        shift 2
        ;;
      --samples)
        [[ "$#" -ge 2 ]] || die "$1 requires a value"
        samples="$2"
        shift 2
        ;;
      --append)
        ui="append"
        shift
        ;;
      --history)
        [[ "$#" -ge 2 ]] || die "$1 requires a value"
        history_limit="$2"
        shift 2
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -* )
        usage >&2
        die "unknown option: $1"
        ;;
      *)
        if [[ "$target_set" -eq 1 ]]; then
          usage >&2
          die "only one path is supported"
        fi
        target="$1"
        target_set=1
        shift
        ;;
    esac
  done

  [[ "$#" -eq 0 ]] || die "unexpected extra arguments: $*"
}

validate_args() {
  [[ -d "$target" ]] || die "path is not a directory: $target"
  [[ "$interval" =~ ^[1-9][0-9]*$ ]] || die "--interval must be a positive integer"
  [[ "$samples" =~ ^[0-9]+$ ]] || die "--samples must be a non-negative integer"
  [[ "$total" =~ ^[0-9]+$ ]] || die "--total must be a non-negative integer"
  [[ "$parallel" =~ ^[0-9]+$ ]] || die "--parallel must be a non-negative integer"
  [[ "$history_limit" =~ ^[1-9][0-9]*$ ]] || die "--history must be a positive integer"
  [[ ! ( "$recursive" -eq 1 && "$include_dirs" -eq 1 ) ]] || die "--include-dirs cannot be used with --recursive"
  [[ "$ui" == "append" || "$ui" == "screen" ]] || die "internal error: unknown ui mode: $ui"
  if [[ "$ui" == "screen" && (! -t 0 || ! -t 1) ]]; then
    ui="append"
  fi
  awk -v a="$alpha" 'BEGIN { exit !(a > 0 && a <= 1) }' || die "--alpha must be in (0, 1]"
}

# Print the table header shared by append output and screen UI.
format_header() {
  if [[ "$total" -gt 0 ]]; then
    printf '%-8s %8s %12s %9s %9s %12s %12s %12s %12s' \
      "time" "scan_s" "count" "delta" "progress" "eta" "raw/s" "smooth/s" "smooth/min"
  else
    printf '%-8s %8s %12s %9s %12s %12s %12s' \
      "time" "scan_s" "count" "delta" "raw/s" "smooth/s" "smooth/min"
  fi
}

# Format one already-computed sample row. This is intentionally side-effect free so
# append mode can print it directly and screen mode can store it in history_rows.
format_sample() {
  local scan_s="$1"
  local count="$2"
  local delta="$3"
  local raw="$4"
  local smooth="$5"
  local smooth_min="$6"
  local progress remaining eta

  if [[ "$total" -gt 0 ]]; then
    progress="$(awk -v c="$count" -v t="$total" 'BEGIN { printf "%.1f%%", c * 100 / t }')"
    remaining=$((total - count))
    eta="$(awk -v remain="$remaining" -v rate="$smooth" 'BEGIN {
      if (remain <= 0) {
        printf "done"
      } else if (rate <= 0) {
        printf "--"
      } else {
        sec = int(remain / rate + 0.5)
        day = int(sec / 86400)
        sec = sec % 86400
        hour = int(sec / 3600)
        sec = sec % 3600
        minute = int(sec / 60)
        second = sec % 60
        if (day > 0) {
          printf "%dd%02d:%02d:%02d", day, hour, minute, second
        } else {
          printf "%02d:%02d:%02d", hour, minute, second
        }
      }
    }')"
    printf '%-8s %8d %12d %+9d %9s %12s %12.4f %12.4f %12.2f' \
      "$(date +%H:%M:%S)" "$scan_s" "$count" "$delta" "$progress" "$eta" "$raw" "$smooth" "$smooth_min"
  else
    printf '%-8s %8d %12d %+9d %12.4f %12.4f %12.2f' \
      "$(date +%H:%M:%S)" "$scan_s" "$count" "$delta" "$raw" "$smooth" "$smooth_min"
  fi
}

# Print the colored intro used by both UI modes. In screen mode render_screen uses
# the same fields, but draws them inside the alternate screen.
print_intro() {
  local total_label="-" status_line keys_line
  [[ "$total" -gt 0 ]] && total_label="$total"
  printf '%sfile_growth%s %s%s%s\n' "$COLOR_BOLD" "$COLOR_RESET" "$COLOR_CYAN" "$target" "$COLOR_RESET"
  status_line="mode=${mode} pattern=${name_pattern:-*} interval=${interval}s alpha=${alpha} total=${total_label} include_dirs=${include_dirs} parallel=${parallel}"
  printf '%s%s%s\n' "$COLOR_DIM" "$status_line" "$COLOR_RESET"
  keys_line="initial_count=${initial_count} initial_scan_s=${initial_scan_s}s scan=idle"
  printf '%s%s%s\n' "$COLOR_YELLOW" "$keys_line" "$COLOR_RESET"
}

# Update global sampling state from a completed count result.
#
# Inputs:
#   $1 scan duration in seconds
#   $2 counted item count
#   $3 scan completion time from date +%s
# Outputs via globals:
#   sample_line, smooth, prev_count, prev_time
update_sample_from_count() {
  local scan_s="$1"
  local now_count="$2"
  local now_time="$3"
  local dt delta raw smooth_min

  dt=$((now_time - prev_time))
  [[ "$dt" -gt 0 ]] || dt="$interval"
  delta=$((now_count - prev_count))

  raw="$(awk -v d="$delta" -v t="$dt" 'BEGIN { printf "%.4f", d / t }')"
  smooth="$(awk -v a="$alpha" -v r="$raw" -v s="$smooth" 'BEGIN { printf "%.4f", a * r + (1 - a) * s }')"
  smooth_min="$(awk -v s="$smooth" 'BEGIN { printf "%.2f", s * 60 }')"
  sample_line="$(format_sample "$scan_s" "$now_count" "$delta" "$raw" "$smooth" "$smooth_min")"

  prev_count="$now_count"
  prev_time="$now_time"
}

# Synchronous sampling for the stable append mode. Do not call through command
# substitution: this function updates global EMA state used by the next sample.
sample_once() {
  local scan_start now_count now_time scan_s

  scan_start="$(date +%s)"
  now_count="$(count_files)"
  now_time="$(date +%s)"
  scan_s=$((now_time - scan_start))
  update_sample_from_count "$scan_s" "$now_count" "$now_time"
}

# Convert one async scan result into sample_line for screen mode. The first
# finished scan establishes a baseline so pre-existing files do not create an
# artificial initial speed spike.
format_scan_result() {
  local scan_s="$1"
  local now_count="$2"
  local now_time="$3"

  if [[ "$screen_has_baseline" -eq 0 ]]; then
    initial_count="$now_count"
    initial_scan_s="$scan_s"
    smooth="0.0000"
    sample_line="$(format_sample "$scan_s" "$now_count" 0 "0.0000" "$smooth" "0.00")"
    prev_count="$now_count"
    prev_time="$now_time"
    screen_has_baseline=1
    return
  fi

  update_sample_from_count "$scan_s" "$now_count" "$now_time"
}

# Start a background count for screen mode. The main UI loop keeps rendering and
# reading keys while this subshell writes one atomic result file.
start_async_scan() {
  [[ -n "${scan_pid:-}" ]] && return

  scan_status="running"
  scan_file="$(mktemp /tmp/file_growth_scan.XXXXXX)"
  (
    scan_start="$(date +%s)"
    scan_count="$(count_files)"
    scan_time="$(date +%s)"
    printf '%s %s %s\n' "$((scan_time - scan_start))" "$scan_count" "$scan_time" > "${scan_file}.tmp"
    mv "${scan_file}.tmp" "$scan_file"
  ) &
  scan_pid="$!"
}

# Collect a completed background count. Returns success only when sample_line has
# been refreshed and is ready to append to history_rows.
collect_async_scan() {
  local scan_s now_count now_time
  [[ -n "${scan_pid:-}" ]] || return 1

  if [[ ! -s "$scan_file" ]]; then
    if ! kill -0 "$scan_pid" 2>/dev/null; then
      wait "$scan_pid" 2>/dev/null || true
      scan_pid=""
      scan_status="error"
    fi
    return 1
  fi

  wait "$scan_pid" 2>/dev/null || true
  scan_pid=""
  read -r scan_s now_count now_time < "$scan_file"
  rm -f "$scan_file" "$scan_file.tmp"
  scan_file=""
  scan_status="idle"
  format_scan_result "$scan_s" "$now_count" "$now_time"
  return 0
}

# Stable default mode: synchronous count, sleep, append one row to stdout.
run_append() {
  local header_line

  print_intro
  header_line="$(format_header)"
  printf '%s%s%s\n' "$COLOR_BOLD$COLOR_BLUE" "$header_line" "$COLOR_RESET"

  while true; do
    sleep "$interval"
    sample_once
    printf '%s\n' "$sample_line"

    ((printed += 1))
    if [[ "$samples" -gt 0 && "$printed" -ge "$samples" ]]; then
      break
    fi
  done
}

# Enter alternate-screen mode and configure /dev/tty for non-blocking key reads.
setup_screen() {
  if exec 3</dev/tty 2>/dev/null; then
    :
  elif exec 3<&0 2>/dev/null; then
    :
  else
    die "interactive screen UI requires a terminal; use --append for stable append output"
  fi
  saved_stty="$(stty -g <&3 2>/dev/null || true)"
  printf '\033[?1049h'
  tput civis 2>/dev/null || true
  stty -echo -icanon time 0 min 0 <&3 2>/dev/null || true
  trap 'cleanup_screen; exit 130' INT TERM
  trap 'cleanup_screen' EXIT
}

# Restore terminal state and stop any in-flight async scan.
cleanup_screen() {
  trap - EXIT INT TERM
  if [[ -n "${scan_pid:-}" ]]; then
    kill "$scan_pid" 2>/dev/null || true
    wait "$scan_pid" 2>/dev/null || true
  fi
  if [[ -n "${scan_file:-}" ]]; then
    rm -f "$scan_file" "$scan_file.tmp"
  fi
  if [[ -n "${saved_stty:-}" ]]; then
    stty "$saved_stty" <&3 2>/dev/null || true
  fi
  exec 3<&- 2>/dev/null || true
  tput cnorm 2>/dev/null || true
  printf '\033[?1049l'
}

# Return current terminal row count for screen layout; falls back to 24.
terminal_rows() {
  local size rows
  size="$(stty size <&3 2>/dev/null || true)"
  rows="${size%% *}"
  if [[ "$rows" =~ ^[1-9][0-9]*$ ]]; then
    printf '%s\n' "$rows"
  else
    tput lines 2>/dev/null || printf '24'
  fi
}

# Return current terminal column count for screen layout; falls back to 80.
terminal_cols() {
  local size cols
  size="$(stty size <&3 2>/dev/null || true)"
  cols="${size##* }"
  if [[ "$cols" =~ ^[1-9][0-9]*$ ]]; then
    printf '%s\n' "$cols"
  else
    tput cols 2>/dev/null || printf '80'
  fi
}

# Print a possibly-colored screen line. The first argument is the printable text
# used for length checks; the second may contain ANSI color sequences.
screen_line() {
  local visible="$1"
  local colored="$2"
  local cols="$3"
  if [[ "${#visible}" -gt "$cols" ]]; then
    printf '%.*s\n' "$cols" "$visible"
  else
    printf '%s\n' "$colored"
  fi
}

# Print a highlighted history row for the current cursor selection.
selected_line() {
  local line="$1"
  local cols="$2"
  printf '%s%s%-*.*s%s\n' "$COLOR_BG_BLUE" "$COLOR_WHITE" "$cols" "$cols" "$line" "$COLOR_RESET"
}

# Largest valid history offset for the current viewport height.
max_view_start() {
  local body_rows="$1"
  local row_count="${#history_rows[@]}"
  local max=$((row_count - body_rows))
  [[ "$max" -gt 0 ]] || max=0
  printf '%s\n' "$max"
}

# Keep selected_index and view_start in bounds while preserving htop-like follow
# behavior at the latest row.
clamp_selection() {
  local body_rows="$1"
  local row_count="${#history_rows[@]}"
  local max_start

  if [[ "$row_count" -le 0 ]]; then
    selected_index=-1
    view_start=0
    follow=1
    return
  fi

  if [[ "$follow" -eq 1 ]]; then
    selected_index=$((row_count - 1))
    view_start="$(max_view_start "$body_rows")"
    return
  fi

  if [[ "$selected_index" -lt 0 ]]; then
    selected_index=0
  elif [[ "$selected_index" -ge "$row_count" ]]; then
    selected_index=$((row_count - 1))
  fi

  if [[ "$selected_index" -lt "$view_start" ]]; then
    view_start="$selected_index"
  elif [[ "$selected_index" -ge $((view_start + body_rows)) ]]; then
    view_start=$((selected_index - body_rows + 1))
  fi

  max_start="$(max_view_start "$body_rows")"
  if [[ "$view_start" -lt 0 ]]; then
    view_start=0
  elif [[ "$view_start" -gt "$max_start" ]]; then
    view_start="$max_start"
  fi

  if [[ "$selected_index" -ge $((row_count - 1)) ]]; then
    follow=1
  fi
}

# Redraw the whole alternate screen: fixed status/header area plus scrollable
# retained history rows.
render_screen() {
  local rows cols body_rows history_body_rows row_count max_start start end i selected_display follow_label total_label header_line title_line status_line keys_line scan_hint scan_hint_visible
  rows="$(terminal_rows)"
  cols="$(terminal_cols)"
  body_rows=$((rows - 4))
  [[ "$body_rows" -gt 0 ]] || body_rows=1
  history_body_rows="$body_rows"
  row_count="${#history_rows[@]}"
  total_label="-"
  [[ "$total" -gt 0 ]] && total_label="$total"

  scan_hint=""
  scan_hint_visible=0
  if [[ "${scan_status:-}" == "running" && "$printed" -lt 2 ]]; then
    if [[ "$printed" -eq 0 ]]; then
      scan_hint="initial scan is running; counting files may take a while..."
    else
      scan_hint="second scan is running; waiting for a real time interval before speed calculation..."
    fi
    scan_hint_visible=1
    history_body_rows=$((body_rows - 1))
    [[ "$history_body_rows" -gt 0 ]] || history_body_rows=1
  fi

  clamp_selection "$history_body_rows"

  start="$view_start"
  end=$((start + history_body_rows))
  [[ "$end" -le "$row_count" ]] || end="$row_count"
  selected_display=0
  [[ "$selected_index" -ge 0 ]] && selected_display=$((selected_index + 1))
  follow_label="off"
  [[ "$follow" -eq 1 ]] && follow_label="on"
  max_start="$(max_view_start "$body_rows")"

  printf '\033[H\033[2J'
  title_line="file_growth $target"
  screen_line "$title_line" "${COLOR_BOLD}file_growth${COLOR_RESET} ${COLOR_CYAN}${target}${COLOR_RESET}" "$cols"
  status_line="mode=${mode} pattern=${name_pattern:-*} interval=${interval}s alpha=${alpha} total=${total_label} include_dirs=${include_dirs} parallel=${parallel}"
  screen_line "$status_line" "${COLOR_DIM}${status_line}${COLOR_RESET}" "$cols"
  keys_line="initial_count=${initial_count} initial_scan_s=${initial_scan_s}s rows=${row_count} selected=${selected_display}/${row_count} follow=${follow_label} view=${view_start}/${max_start} scan=${scan_status}  press h or ? for help"
  screen_line "$keys_line" "${COLOR_YELLOW}${keys_line}${COLOR_RESET}" "$cols"

  if [[ "$show_help" -eq 1 ]]; then
    screen_line "" "" "$cols"
    screen_line "Screen UI keys" "${COLOR_BOLD}${COLOR_MAGENTA}Screen UI keys${COLOR_RESET}" "$cols"
    screen_line "  h / ?              Toggle this help panel" "  ${COLOR_BOLD}h / ?${COLOR_RESET}              Toggle this help panel" "$cols"
    screen_line "  q                  Close help panel; quit from monitor" "  ${COLOR_BOLD}q${COLOR_RESET}                  Close help panel; quit from monitor" "$cols"
    screen_line "  Esc                Close help panel only" "  ${COLOR_BOLD}Esc${COLOR_RESET}                Close help panel only" "$cols"
    screen_line "  k / Up             Scroll up to older rows" "  ${COLOR_BOLD}k / Up${COLOR_RESET}             Scroll up to older rows" "$cols"
    screen_line "  j / Down           Scroll down to newer rows" "  ${COLOR_BOLD}j / Down${COLOR_RESET}           Scroll down to newer rows" "$cols"
    screen_line "  PageUp / PageDown  Scroll one page" "  ${COLOR_BOLD}PageUp / PageDown${COLOR_RESET}  Scroll one page" "$cols"
    screen_line "  g                  Jump to oldest retained row" "  ${COLOR_BOLD}g${COLOR_RESET}                  Jump to oldest retained row" "$cols"
    screen_line "  G / End            Jump to latest row and follow new samples" "  ${COLOR_BOLD}G / End${COLOR_RESET}            Jump to latest row and follow new samples" "$cols"
    screen_line "" "" "$cols"
    screen_line "Press h, ?, or q to return to the monitor." "${COLOR_DIM}Press h, ?, or q to return to the monitor.${COLOR_RESET}" "$cols"
    return
  fi

  header_line="$(format_header)"
  screen_line "$header_line" "${COLOR_BOLD}${COLOR_BLUE}${header_line}${COLOR_RESET}" "$cols"

  if [[ "$scan_hint_visible" -eq 1 ]]; then
    screen_line "$scan_hint" "${COLOR_DIM}${COLOR_YELLOW}${scan_hint}${COLOR_RESET}" "$cols"
  fi

  for ((i = start; i < end; i++)); do
    if [[ "$i" -eq "$selected_index" ]]; then
      selected_line "${history_rows[$i]}" "$cols"
    else
      screen_line "${history_rows[$i]}" "${history_rows[$i]}" "$cols"
    fi
  done
}

# Handle one keypress from /dev/tty. Returns non-zero only when the monitor
# should quit; q in help closes help instead of exiting.
handle_key() {
  local key rest page_rows
  read -rsn1 -t 1 key <&3 || return 0
  page_rows=$(($(terminal_rows) - 4))
  [[ "$page_rows" -gt 0 ]] || page_rows=1

  case "$key" in
    q)
      if [[ "$show_help" -eq 1 ]]; then
        screen_needs_render=1
        show_help=0
        return 0
      fi
      return 1
      ;;
    h | \?)
      screen_needs_render=1
      if [[ "$show_help" -eq 1 ]]; then
        show_help=0
      else
        show_help=1
      fi
      ;;
    k)
      screen_needs_render=1
      show_help=0
      follow=0
      selected_index=$((selected_index - 1))
      ;;
    j)
      screen_needs_render=1
      show_help=0
      selected_index=$((selected_index + 1))
      ;;
    g)
      screen_needs_render=1
      show_help=0
      follow=0
      selected_index=0
      ;;
    G)
      screen_needs_render=1
      show_help=0
      follow=1
      selected_index=$((${#history_rows[@]} - 1))
      ;;
    $'\e')
      read -rsn1 -t 1 rest <&3 || rest=""
      if [[ -z "$rest" ]]; then
        if [[ "$show_help" -eq 1 ]]; then
          screen_needs_render=1
          show_help=0
        fi
        return 0
      fi
      if [[ "$rest" == "[" ]]; then
        read -rsn1 -t 1 rest <&3 || rest=""
        case "$rest" in
          A)
            screen_needs_render=1
            show_help=0
            follow=0
            selected_index=$((selected_index - 1))
            ;;
          B)
            screen_needs_render=1
            show_help=0
            selected_index=$((selected_index + 1))
            ;;
          5)
            read -rsn1 -t 1 rest <&3 || true
            screen_needs_render=1
            show_help=0
            follow=0
            selected_index=$((selected_index - page_rows))
            ;;
          6)
            read -rsn1 -t 1 rest <&3 || true
            screen_needs_render=1
            show_help=0
            selected_index=$((selected_index + page_rows))
            ;;
          F)
            screen_needs_render=1
            show_help=0
            follow=1
            selected_index=$((${#history_rows[@]} - 1))
            ;;
          H)
            screen_needs_render=1
            show_help=0
            follow=0
            selected_index=0
            ;;
        esac
      fi
      ;;
  esac

  clamp_selection "$page_rows"
  return 0
}

# Add the latest sample_line to screen history and drop oldest retained rows when
# --history is exceeded.
append_history() {
  history_rows+=("$sample_line")
  while [[ "${#history_rows[@]}" -gt "$history_limit" ]]; do
    history_rows=("${history_rows[@]:1}")
    if [[ "$selected_index" -gt 0 ]]; then
      selected_index=$((selected_index - 1))
    fi
    if [[ "$view_start" -gt 0 ]]; then
      view_start=$((view_start - 1))
    fi
  done
  if [[ "$follow" -eq 1 ]]; then
    selected_index=$((${#history_rows[@]} - 1))
  fi
}

# Interactive screen UI: async counting, fixed header, retained-history scrolling.
run_screen() {
  local next_scan_time now
  setup_screen
  start_async_scan
  render_screen
  next_scan_time=$(( $(date +%s) + interval ))

  while true; do
    if ! handle_key; then
      break
    fi
    if [[ "$screen_needs_render" -eq 1 ]]; then
      render_screen
      screen_needs_render=0
    fi

    now="$(date +%s)"
    if collect_async_scan; then
      append_history
      ((printed += 1))
      render_screen

      if [[ "$samples" -gt 0 && "$printed" -ge "$samples" ]]; then
        break
      fi
      next_scan_time=$((now + interval))
    fi

    if [[ -z "${scan_pid:-}" && "$now" -ge "$next_scan_time" ]]; then
      start_async_scan
      render_screen
    fi

  done

  cleanup_screen
}

parse_args "$@"
validate_args

target="$(cd "$target" && pwd -P)"
mode="recursive"
[[ "$recursive" -eq 1 ]] || mode="non-recursive"

case "$ui" in
  append)
    initial_scan_start="$(date +%s)"
    prev_count="$(count_files)"
    initial_count="$prev_count"
    prev_time="$(date +%s)"
    initial_scan_s=$((prev_time - initial_scan_start))
    smooth="0"
    printed=0
    sample_line=""
    run_append
    ;;
  screen)
    prev_count=0
    initial_count="pending"
    prev_time="$(date +%s)"
    initial_scan_s=0
    smooth="0"
    printed=0
    sample_line=""
    saved_stty=""
    scan_pid=""
    scan_file=""
    scan_status="idle"
    screen_has_baseline=0
    declare -a history_rows=()
    follow=1
    selected_index=-1
    view_start=0
    screen_needs_render=0
    show_help=0
    run_screen
    ;;
esac
