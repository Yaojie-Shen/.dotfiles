#!/usr/bin/env bash

set -euo pipefail

audio="left"
scale="1"
duration=""
timestamp=0
timestamp_size="28"
output=""
force=0

usage() {
  local cmd
  cmd="$(basename "$0")"

  cat <<EOF
usage: ${cmd} <left.mp4> <right.mp4> [options]

Preview two videos side by side with ffplay, or export the same view with ffmpeg.
Preview window title is "${cmd}: <left.mp4> vs <right.mp4>".

dependencies:
  ffplay must be installed and available in PATH for preview mode.
  ffmpeg must be installed and available in PATH for export mode.
  ffplay and ffmpeg are shipped with FFmpeg.
  Timestamp overlay uses FFmpeg's drawtext filter when --timestamp is enabled.
  On macOS, install it with: brew install ffmpeg

options:
  --audio MODE       Select audio source: left, right, or none. Default: left
  --scale FLOAT      Scale each input video before stacking. Default: 1 (original size)
  --duration SECOND  Stop playback after SECOND seconds. Useful for smoke tests.
  --timestamp        Overlay each video with its playback timestamp. Default: disabled
  --timestamp-size N Timestamp font size in pixels. Default: 28
  --output FILE      Export the same side-by-side view to FILE with ffmpeg instead of opening ffplay
  --export FILE      Alias for --output
  --overwrite, --force
                    Overwrite output file in export mode
  -h, --help         Show this help message and exit

examples:
  ${cmd} left.mp4 right.mp4
  ${cmd} left.mp4 right.mp4 --audio right
  ${cmd} left.mp4 right.mp4 --audio none --scale 0.5
  ${cmd} left.mp4 right.mp4 --timestamp
  ${cmd} left.mp4 right.mp4 --audio none --duration 3
  ${cmd} left.mp4 right.mp4 --timestamp --output side_by_side.mp4
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

is_positive_number() {
  [[ "$1" =~ ^([0-9]+([.][0-9]+)?|[.][0-9]+)$ ]] && awk -v n="$1" 'BEGIN { exit !(n > 0) }'
}

is_positive_integer() {
  [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

escape_lavfi_value() {
  local input="$1"
  local output=""
  local char
  local i

  for ((i = 0; i < ${#input}; i++)); do
    char="${input:i:1}"
    case "$char" in
      '\\' | "'" | ':' | '[' | ']' | ',' | ';' | '=' | ' ')
        output+="\\${char}"
        ;;
      *)
        output+="${char}"
        ;;
    esac
  done

  printf '%s' "$output"
}

build_video_filter_chain() {
  local input_label="$1"
  local output_label="$2"
  local chain

  chain="${input_label}"
  if [[ "$scale" != "1" ]]; then
    chain+="scale=iw*${scale}:ih*${scale},"
  fi
  chain+="setsar=1"
  if [[ "$timestamp" -eq 1 ]]; then
    chain+=",drawtext=text='%{pts\\:hms}':x=16:y=16:fontsize=${timestamp_size}:fontcolor=white:box=1:boxcolor=black@0.55"
  fi
  chain+="${output_label}"

  printf '%s' "$chain"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "$#" -lt 2 ]]; then
  usage >&2
  exit 1
fi

left="$1"
right="$2"
shift 2

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --audio)
      [[ "$#" -ge 2 ]] || die "--audio requires a value"
      audio="$2"
      shift 2
      ;;
    --scale)
      [[ "$#" -ge 2 ]] || die "--scale requires a value"
      scale="$2"
      shift 2
      ;;
    --duration)
      [[ "$#" -ge 2 ]] || die "--duration requires a value"
      duration="$2"
      shift 2
      ;;
    --timestamp)
      timestamp=1
      shift
      ;;
    --no-timestamp)
      timestamp=0
      shift
      ;;
    --timestamp-size)
      [[ "$#" -ge 2 ]] || die "--timestamp-size requires a value"
      timestamp_size="$2"
      shift 2
      ;;
    --output | --export)
      [[ "$#" -ge 2 ]] || die "$1 requires a value"
      output="$2"
      shift 2
      ;;
    --overwrite | --force)
      force=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

[[ -f "$left" ]] || die "file not found: $left"
[[ -f "$right" ]] || die "file not found: $right"

case "$audio" in
  left | right | none) ;;
  *) die "--audio must be one of: left, right, none" ;;
esac

is_positive_number "$scale" || die "--scale must be a positive number"
if [[ -n "$duration" ]]; then
  is_positive_number "$duration" || die "--duration must be a positive number"
fi
is_positive_integer "$timestamp_size" || die "--timestamp-size must be a positive integer"

if [[ -n "$output" ]]; then
  command -v ffmpeg >/dev/null 2>&1 || die "ffmpeg not found. Install FFmpeg first, for example: brew install ffmpeg"
else
  command -v ffplay >/dev/null 2>&1 || die "ffplay not found. Install FFmpeg first, for example: brew install ffmpeg"
fi

if [[ -n "$output" && -e "$output" && "$force" -eq 0 ]]; then
  die "output file already exists: $output (use --overwrite to overwrite)"
fi

if [[ -z "$output" && "$force" -eq 1 ]]; then
  die "--overwrite can only be used with --output"
fi

if [[ -n "$output" ]]; then
  left_video_chain="$(build_video_filter_chain '[0:v]' '[v0]')"
  right_video_chain="$(build_video_filter_chain '[1:v]' '[v1]')"
  filter_complex="${left_video_chain};${right_video_chain};[v0][v1]hstack=inputs=2[outv]"

  ffmpeg_args=(
    -hide_banner
    -loglevel error
  )

  if [[ "$force" -eq 1 ]]; then
    ffmpeg_args+=(-y)
  else
    ffmpeg_args+=(-n)
  fi

  ffmpeg_args+=(
    -i "$left"
    -i "$right"
    -filter_complex "$filter_complex"
    -map '[outv]'
  )

  case "$audio" in
    left)
      ffmpeg_args+=(-map '0:a?')
      ;;
    right)
      ffmpeg_args+=(-map '1:a?')
      ;;
    none)
      ffmpeg_args+=(-an)
      ;;
  esac

  if [[ -n "$duration" ]]; then
    ffmpeg_args+=(-t "$duration")
  fi

  ffmpeg_args+=(
    -c:v libx264
    -crf 18
    -preset medium
    -pix_fmt yuv420p
  )

  if [[ "$audio" != "none" ]]; then
    ffmpeg_args+=(
      -c:a aac
      -b:a 192k
      -shortest
    )
  fi

  exec ffmpeg "${ffmpeg_args[@]}" "$output"
fi

left_filter="$(escape_lavfi_value "$left")"
right_filter="$(escape_lavfi_value "$right")"
window_title="$(basename "$0"): ${left} vs ${right}"
timestamp_filter=""
if [[ "$timestamp" -eq 1 ]]; then
  timestamp_filter=",drawtext=text='%{pts\\:hms}':x=16:y=16:fontsize=${timestamp_size}:fontcolor=white:box=1:boxcolor=black@0.55"
fi

if [[ "$scale" == "1" ]]; then
  filter="movie=filename=${left_filter},setsar=1${timestamp_filter}[v0];"
  filter+="movie=filename=${right_filter},setsar=1${timestamp_filter}[v1];"
else
  filter="movie=filename=${left_filter},scale=iw*${scale}:ih*${scale},setsar=1${timestamp_filter}[v0];"
  filter+="movie=filename=${right_filter},scale=iw*${scale}:ih*${scale},setsar=1${timestamp_filter}[v1];"
fi
filter+="[v0][v1]hstack=inputs=2[out0]"

ffplay_args=(
  -hide_banner
  -loglevel error
  -window_title "$window_title"
  -autoexit
)

if [[ -n "$duration" ]]; then
  ffplay_args+=(-t "$duration")
fi

case "$audio" in
  left)
    audio_filter="$left_filter"
    filter+=";amovie=filename=${audio_filter}[out1]"
    ;;
  right)
    audio_filter="$right_filter"
    filter+=";amovie=filename=${audio_filter}[out1]"
    ;;
  none)
    ffplay_args+=(-an)
    ;;
esac

exec ffplay "${ffplay_args[@]}" -f lavfi -i "$filter"
