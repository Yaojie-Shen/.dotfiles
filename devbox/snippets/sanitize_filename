#!/usr/bin/env bash

set -euo pipefail

show_help() {
  cat <<EOF
usage: $(basename "$0") <string>

Convert <string> to lowercase, replace non-alphanumeric characters with '_',
and trim leading/trailing '_' characters.

options:
  -h, --help  Show this help message and exit

examples:
  $(basename "$0") "Hello World!"
  # -> hello_world
EOF
  exit 0
}

sanitize_filename() {
    printf "%s" "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/_/g; s/^_+|_+$//g'
}

case "${1:-}" in
    -h|--help|"")
        show_help
        ;;
esac

sanitize_filename "$1"
