#!/usr/bin/env bash

set -uo pipefail

usage() {
  local cmd
  cmd="$(basename "$0")"

  cat <<EOF
usage: ${cmd}

Pull the latest changes for the dotfiles repository and its optional custom
repository. The command does not depend on the current working directory.

environment:
  DOTFILES_ROOT         Dotfiles repository path. Default: \$HOME/.dotfiles
  DOTFILES_CUSTOM_ROOT  Custom repository path.
                        Default: \$DOTFILES_ROOT/persistent/custom

options:
  -h, --help            Show this help message and exit

examples:
  ${cmd}
  DOTFILES_ROOT=/path/to/dotfiles ${cmd}
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

update_repository() {
  local label="$1"
  local repository="$2"

  echo "==> Updating ${label}: ${repository}"
  if git -C "$repository" pull --ff-only; then
    echo "Updated ${label} successfully"
    return 0
  fi

  echo "Error: failed to update ${label}: ${repository}" >&2
  return 1
}

is_git_repository_root() {
  local repository="$1"
  local repository_root
  local requested_root

  repository_root="$(git -C "$repository" rev-parse --show-toplevel 2>/dev/null)" || return 1
  repository_root="$(cd "$repository_root" && pwd -P)" || return 1
  requested_root="$(cd "$repository" && pwd -P)" || return 1
  [[ "$repository_root" == "$requested_root" ]]
}

case "${1:-}" in
  "")
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    die "unknown argument: $1"
    ;;
esac

command -v git >/dev/null 2>&1 || die "git is required"

dotfiles_root="${DOTFILES_ROOT:-${HOME}/.dotfiles}"
custom_root="${DOTFILES_CUSTOM_ROOT:-${dotfiles_root}/persistent/custom}"

[[ -d "$dotfiles_root" ]] || die "dotfiles directory not found: $dotfiles_root"
is_git_repository_root "$dotfiles_root" ||
  die "dotfiles directory is not a Git repository: $dotfiles_root"

status=0
update_repository "dotfiles" "$dotfiles_root" || status=1

if [[ ! -e "$custom_root" ]]; then
  echo "==> Custom repository not found; skipping: ${custom_root}"
elif [[ ! -d "$custom_root" ]]; then
  echo "Error: custom repository path is not a directory: ${custom_root}" >&2
  status=1
elif ! is_git_repository_root "$custom_root"; then
  echo "Error: custom directory is not a Git repository: ${custom_root}" >&2
  status=1
else
  update_repository "custom" "$custom_root" || status=1
fi

exit "$status"
