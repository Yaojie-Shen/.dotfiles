#!/usr/bin/env bash
# Summary: Run devbox setup scripts
# Usage: devbox setup -l|--list
#        devbox setup <script_name> [<args>]

set -e

source "${BASH_SOURCE%/*}/devbox-utils"

[ -n "$DEVBOX_DEBUG" ] && set -x

setup_dirs=()
custom_root="${DEVBOX_CUSTOM_ROOT:-${HOME}/.persistent/custom/devbox}"
custom_root="${custom_root%/}"
setup_path="${DEVBOX_SETUP_PATH:-${DEVBOX_ROOT}/setup:${custom_root}/setup}"

IFS=: read -r -a setup_candidates <<<"$setup_path"
for setup_dir in "${setup_candidates[@]}"; do
  [[ -d "$setup_dir" ]] || continue
  setup_dir="$(cd "$setup_dir" && pwd -P)"
  setup_dir_seen=0
  for existing_setup_dir in "${setup_dirs[@]}"; do
    if [[ "$existing_setup_dir" == "$setup_dir" ]]; then
      setup_dir_seen=1
      break
    fi
  done
  if [[ "$setup_dir_seen" -eq 0 ]]; then
    setup_dirs+=("$setup_dir")
  fi
done

has_script_name() {
  local name="$1"
  local existing
  for existing in "${script_names[@]}"; do
    if [[ "$existing" == "$name" ]]; then
      return 0
    fi
  done
  return 1
}

# Discover setup scripts
shopt -s dotglob nullglob
script_names=()
script_paths=()
for setup_dir in "${setup_dirs[@]}"; do
  for setup_script in "$setup_dir"/*; do
    [[ -f "$setup_script" ]] || continue
    script_name="${setup_script##*/}"
    if ! has_script_name "$script_name"; then
      script_names+=("$script_name")
      script_paths+=("$setup_script")
    fi
  done
done
shopt -u dotglob nullglob

# Provide devbox completions
case "$1" in
--complete)
  printf "%s\n" "${script_names[@]}"
  exit
  ;;
--list | -l)
  info "Finding scripts in:"
  printf " - %s\n" "${setup_dirs[@]}"
  success "Available setup scripts:"
  printf " - %s\n" "${script_names[@]}"
  exit
  ;;
-*)
  devbox-help --usage setup >&2
  exit 1
  ;;
*)
  SCRIPT_NAME=$1
  shift
  ;;
esac

for i in "${!script_names[@]}"; do
  if [[ "${script_names[$i]}" == "$SCRIPT_NAME" ]]; then
    "${script_paths[$i]}" "$@"
    exit
  fi
done

info "Finding scripts in:"
printf " - %s\n" "${setup_dirs[@]}"
error "Setup script not found: ${SCRIPT_NAME}"
