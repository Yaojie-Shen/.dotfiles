#!/usr/bin/env bash
# Summary: Run user-defined shell snippets
# Usage: devbox snippets <snippet_name>
#        devbox snippets --list|-l                # List all snippets
#        devbox snippets --add <path>             # Add snippet
#        devbox snippets --remove <snippet_name>  # Remove snippet
#        devbox snippets --edit <snippet_name>    # Edit snippet

set -e
[ -n "$DEVBOX_DEBUG" ] && set -x

snippet_dir="${DEVBOX_ROOT}/snippets"

if [ -d "$snippet_dir" ]; then
  snippet_dir="$(cd "$snippet_dir" && pwd -P)"
fi

snippet_dirs=()
custom_root="${DEVBOX_CUSTOM_ROOT:-${HOME}/.persistent/custom/devbox}"
custom_root="${custom_root%/}"
snippets_path="${DEVBOX_SNIPPETS_PATH:-${DEVBOX_ROOT}/snippets:${custom_root}/snippets}"

IFS=: read -r -a snippet_candidates <<<"$snippets_path"
for discovered_snippet_dir in "${snippet_candidates[@]}"; do
  [[ -d "$discovered_snippet_dir" ]] || continue
  discovered_snippet_dir="$(cd "$discovered_snippet_dir" && pwd -P)"
  snippet_dir_seen=0
  for existing_snippet_dir in "${snippet_dirs[@]}"; do
    if [[ "$existing_snippet_dir" == "$discovered_snippet_dir" ]]; then
      snippet_dir_seen=1
      break
    fi
  done
  if [[ "$snippet_dir_seen" -eq 0 ]]; then
    snippet_dirs+=("$discovered_snippet_dir")
  fi
done

has_snippet_name() {
  local name="$1"
  local existing
  for existing in "${snippet_names[@]}"; do
    if [[ "$existing" == "$name" ]]; then
      return 0
    fi
  done
  return 1
}

# Discover snippets
shopt -s dotglob nullglob
snippet_names=()
snippet_paths=()
for discovered_snippet_dir in "${snippet_dirs[@]}"; do
  for snippet_path in "${discovered_snippet_dir}"/*; do
    [[ -f "$snippet_path" ]] || continue
    snippet_name="${snippet_path##*/}"
    if ! has_snippet_name "$snippet_name"; then
      snippet_names+=("$snippet_name")
      snippet_paths+=("$snippet_path")
    fi
  done
done
shopt -u dotglob nullglob

# Provide devbox completions
if [ "${1:-}" = '--complete' ]; then
  case "${2:-}" in
  --remove | -r | --edit | -e)
    printf "%s\n" "${snippet_names[@]}"
    ;;
  *)
    echo "--add"
    echo "--remove"
    echo "--list"
    echo "--edit"
    ;;
  esac
  exit
fi

add_snippet() {
  for path; do
    if [ ! -f $path ]; then
      echo "$path is not a valid file."
      continue
    fi
    name=${path##*/}
    if [ -f "${snippet_dir}/${name}" ]; then
      echo "A snippet named $name already exist."
      continue
    fi

    mkdir -p "${snippet_dir}"
    cp "${path}" "${snippet_dir}"
    chmod +x "${snippet_dir}/${name}"

    echo "Add snippet: ${name}"
    echo "Now, you can use it directly:"
    echo "> ${name} ..."
  done
}

remove_snippet() {
  for name; do
    if [ ! -f "${snippet_dir}/${name}" ]; then
      echo "Snippet named ${name} do not exist."
      continue
    fi

    mkdir -p "${snippet_dir}/.trash"
    mv "${snippet_dir}/${name}" "${snippet_dir}/.trash"
    echo "Move snippet ${name} to trash."
  done
}

edit_snippet() {
  for name; do
    mkdir -p "${snippet_dir}"
    vi "${snippet_dir}/$name"
    if [ -f "${snippet_dir}/${name}" ]; then
      chmod +x "${snippet_dir}/${name}"
    fi
  done
}

case "$1" in
--list | -l)
  echo "Snippet directories:"
  printf " - %s\n" "${snippet_dirs[@]}"
  echo "Available snippets: "
  printf " - %s\n" "${snippet_names[@]}"
  exit
  ;;
--add | -a)
  shift
  add_snippet "$@"
  ;;
--remove | -r)
  shift
  remove_snippet "$@"
  ;;
--edit | -e)
  shift
  edit_snippet "$@"
  exit
  ;;
*)
  devbox-help --usage snippets
  ;;
esac
