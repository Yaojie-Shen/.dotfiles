#!/usr/bin/env bash

set -Eeuo pipefail

ACTION="install"
CODEX_RELEASE="latest"
INSTALL_DIR="${CODEX_INSTALL_DIR:-${HOME}/.local/bin}"
CODEX_HOME_DIR="${CODEX_HOME:-${HOME}/.codex}"
INSTALLER_URL="https://chatgpt.com/codex/install.sh"
NON_INTERACTIVE=1
FORCE_REMOVE_BIN=0

DEVBOX_UTILS="${DEVBOX_UTILS:-${DEVBOX_ROOT:-${HOME}/.devbox}/libexec/devbox-utils}"
if [[ ! -f "$DEVBOX_UTILS" ]]; then
  echo "Error: devbox-utils not found at: $DEVBOX_UTILS" >&2
  exit 1
fi
# shellcheck disable=SC1090
source "$DEVBOX_UTILS"

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

Behavior:
  - Installs or updates Codex CLI on macOS/Linux using the official standalone installer.
  - Defaults to non-interactive mode so setup will not prompt to launch Codex.
  - Keeps Codex config/auth under ~/.codex when uninstalling; only standalone package files are removed.
  - Reports PATH conflicts with older brew/npm/bun-managed Codex installs.

Options:
  -h, --help              Show this help message
  -u, --uninstall         Remove the standalone Codex CLI install managed by the official installer
  --upgrade               Re-run the installer for the selected release (default action also updates)
  --status                Show detected Codex CLI install state
  --doctor                Show install state and run basic dependency checks
  --version <VERSION>     Install a specific Codex release (default: latest)
  --release <VERSION>     Alias for --version
  --install-dir <DIR>     Directory for the codex command (default: ~/.local/bin)
  --codex-home <DIR>      Codex home directory (default: ~/.codex)
  --installer-url <URL>   Override official installer URL
  --interactive           Allow official installer prompts
  --force-remove-bin      During uninstall, remove codex at --install-dir even if it is not a symlink

Examples:
  $(basename "$0")
  $(basename "$0") --version 0.43.0
  $(basename "$0") --status
  $(basename "$0") --uninstall
EOF
  exit 0
}

require_value() {
  local option="${1:-}"
  local value="${2:-}"

  if [[ -z "$value" || "$value" == -* ]]; then
    error "Missing value for $option"
    return 1
  fi
}

codex_bin_path() {
  printf '%s\n' "${INSTALL_DIR%/}/codex"
}

standalone_root() {
  printf '%s\n' "${CODEX_HOME_DIR%/}/packages/standalone"
}

current_link() {
  printf '%s\n' "$(standalone_root)/current"
}

command_path() {
  command -v codex 2>/dev/null || true
}

download_installer() {
  local output="$1"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$INSTALLER_URL" -o "$output"
    return
  fi

  if command -v wget >/dev/null 2>&1; then
    wget -q -O "$output" "$INSTALLER_URL"
    return
  fi

  error "curl or wget is required to download the Codex installer"
  return 1
}

check_supported_platform() {
  local os arch
  os="$(uname -s)"
  arch="$(uname -m)"

  case "$os" in
  Darwin | Linux) ;;
  *)
    error "Unsupported OS: $os. This setup script supports macOS and Linux only."
    return 1
    ;;
  esac

  case "$arch" in
  x86_64 | amd64 | arm64 | aarch64) ;;
  *)
    error "Unsupported architecture: $arch"
    return 1
    ;;
  esac
}

check_prerequisites() {
  local missing=()

  command -v mktemp >/dev/null 2>&1 || missing+=(mktemp)
  command -v tar >/dev/null 2>&1 || missing+=(tar)
  command -v curl >/dev/null 2>&1 || command -v wget >/dev/null 2>&1 || missing+=(curl-or-wget)

  if ! command -v sha256sum >/dev/null 2>&1 &&
    ! command -v shasum >/dev/null 2>&1 &&
    ! command -v openssl >/dev/null 2>&1; then
    missing+=(sha256sum-or-shasum-or-openssl)
  fi

  if [[ "${#missing[@]}" -gt 0 ]]; then
    error "Missing required command(s): ${missing[*]}"
    return 1
  fi
}

print_codex_version() {
  local path="$1"

  if [[ -x "$path" ]]; then
    "$path" --version 2>/dev/null || true
  fi
}

classify_codex_path() {
  local path="$1"

  if [[ -z "$path" ]]; then
    printf 'none\n'
    return 0
  fi

  if [[ "$path" == "$(codex_bin_path)" ]]; then
    printf 'standalone\n'
    return 0
  fi

  case "$path" in
  /Applications/Codex.app/*)
    printf 'codex-app-bundled\n'
    return 0
    ;;
  esac

  case "$path" in
  /opt/homebrew/* | /usr/local/*)
    if [[ "$(uname -s)" == "Darwin" ]]; then
      printf 'possibly-homebrew\n'
      return 0
    fi
    ;;
  esac

  if [[ -f "$path" ]] && grep -F "#!/usr/bin/env node" "$path" >/dev/null 2>&1; then
    case "$path" in
    *".bun"*) printf 'possibly-bun\n' ;;
    *) printf 'possibly-npm\n' ;;
    esac
    return 0
  fi

  printf 'external\n'
}

status() {
  local bin_path resolved manager root current
  bin_path="$(codex_bin_path)"
  resolved="$(command_path)"
  manager="$(classify_codex_path "$resolved")"
  root="$(standalone_root)"
  current="$(current_link)"

  info "Codex CLI status"
  printf '  command on PATH: %s\n' "${resolved:-not found}"
  printf '  expected command: %s\n' "$bin_path"
  printf '  detected source:  %s\n' "$manager"
  printf '  install dir:      %s\n' "$INSTALL_DIR"
  printf '  codex home:       %s\n' "$CODEX_HOME_DIR"
  printf '  standalone root:  %s\n' "$root"

  if [[ -L "$bin_path" ]]; then
    printf '  command symlink:  %s -> %s\n' "$bin_path" "$(readlink "$bin_path")"
  elif [[ -e "$bin_path" ]]; then
    printf '  command file:     %s\n' "$bin_path"
  else
    printf '  command file:     missing\n'
  fi

  if [[ -L "$current" ]]; then
    printf '  current release:  %s -> %s\n' "$current" "$(readlink "$current")"
  elif [[ -e "$current" ]]; then
    printf '  current release:  %s\n' "$current"
  else
    printf '  current release:  missing\n'
  fi

  if [[ -x "$bin_path" ]]; then
    printf '  installed:        '
    print_codex_version "$bin_path"
  elif [[ -n "$resolved" ]]; then
    printf '  path version:     '
    print_codex_version "$resolved"
  fi

  if [[ -n "$resolved" && "$resolved" != "$bin_path" ]]; then
    warning "PATH resolves codex to $resolved instead of $bin_path"
  fi
}

doctor() {
  local ok=1

  status
  printf '\n'
  info "Checking prerequisites"

  if check_supported_platform; then
    success "Platform is supported"
  else
    ok=0
  fi

  if check_prerequisites; then
    success "Required commands are available"
  else
    ok=0
  fi

  if [[ "$ok" -eq 1 ]]; then
    success "Codex CLI setup checks passed"
  else
    error "Codex CLI setup checks failed"
    return 1
  fi
}

install_codex() {
  local tmp_dir installer non_interactive_value

  check_supported_platform
  check_prerequisites

  tmp_dir="$(mktemp -d)"
  installer="$tmp_dir/install.sh"
  trap "rm -rf '$tmp_dir'" EXIT

  non_interactive_value="true"
  if [[ "$NON_INTERACTIVE" -eq 0 ]]; then
    non_interactive_value="false"
  fi

  info "Downloading official Codex CLI installer from $INSTALLER_URL"
  download_installer "$installer"

  info "Installing Codex CLI release: $CODEX_RELEASE"
  CODEX_INSTALL_DIR="$INSTALL_DIR" \
    CODEX_HOME="$CODEX_HOME_DIR" \
    CODEX_NON_INTERACTIVE="$non_interactive_value" \
    CODEX_RELEASE="$CODEX_RELEASE" \
    sh "$installer" --release "$CODEX_RELEASE"

  rm -rf "$tmp_dir"
  trap - EXIT

  printf '\n'
  status
  printf '\n'
  success "Codex CLI setup complete"
}

remove_codex_path_blocks() {
  local rc

  for rc in "$HOME/.zprofile" "$HOME/.bash_profile" "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
    if [[ -f "$rc" ]] && grep -Fq "# >>> Codex installer >>>" "$rc"; then
      info "Removing Codex PATH block from $rc"
      remove_rc_block "$rc" "# >>> Codex installer >>>" "# <<< Codex installer <<<"
    fi
  done
}

remove_codex_bin() {
  local bin_path target
  bin_path="$(codex_bin_path)"

  if [[ -L "$bin_path" ]]; then
    target="$(readlink "$bin_path")"
    info "Removing Codex command symlink: $bin_path -> $target"
    rm -f "$bin_path"
    return 0
  fi

  if [[ -f "$bin_path" ]]; then
    if [[ "$FORCE_REMOVE_BIN" -eq 1 ]]; then
      warning "Removing regular file because --force-remove-bin was set: $bin_path"
      rm -f "$bin_path"
      return 0
    fi

    warning "Skipping regular file at $bin_path. Use --force-remove-bin to remove it."
    return 1
  fi

  return 1
}

uninstall_codex() {
  local removed_any=0 root
  root="$(standalone_root)"

  if remove_codex_bin; then
    removed_any=1
  fi

  if [[ -e "$root" || -L "$root" ]]; then
    info "Removing standalone Codex packages: $root"
    rm -rf "$root"
    removed_any=1
  fi

  remove_codex_path_blocks

  if [[ "$removed_any" -eq 1 ]]; then
    success "Codex CLI standalone install removed. Config and auth under $CODEX_HOME_DIR were kept."
  else
    warning "Codex CLI standalone install was not found"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
    usage
    ;;
  -u | --uninstall)
    ACTION="uninstall"
    shift
    ;;
  --upgrade)
    ACTION="install"
    shift
    ;;
  --status)
    ACTION="status"
    shift
    ;;
  --doctor)
    ACTION="doctor"
    shift
    ;;
  --version | --release)
    require_value "$1" "${2:-}"
    CODEX_RELEASE="$2"
    shift 2
    ;;
  --install-dir)
    require_value "$1" "${2:-}"
    INSTALL_DIR="$2"
    shift 2
    ;;
  --codex-home)
    require_value "$1" "${2:-}"
    CODEX_HOME_DIR="$2"
    shift 2
    ;;
  --installer-url)
    require_value "$1" "${2:-}"
    INSTALLER_URL="$2"
    shift 2
    ;;
  --interactive)
    NON_INTERACTIVE=0
    shift
    ;;
  --force-remove-bin)
    FORCE_REMOVE_BIN=1
    shift
    ;;
  *)
    error "Unknown option: $1"
    usage
    ;;
  esac
done

case "$ACTION" in
install)
  install_codex
  ;;
uninstall)
  uninstall_codex
  ;;
status)
  status
  ;;
doctor)
  doctor
  ;;
*)
  error "Unknown action: $ACTION"
  exit 1
  ;;
esac
