#!/usr/bin/env bash

set -Eeuo pipefail

ACTION="install"
NVM_DIR="${NVM_DIR:-${HOME}/.nvm}"
NVM_VERSION=""
INSTALL_LTS=0

DEVBOX_UTILS="${DEVBOX_UTILS:-${DEVBOX_ROOT:-${HOME}/.devbox}/libexec/devbox-utils}"
if [[ ! -f "$DEVBOX_UTILS" ]]; then
  echo "Error: devbox-utils not found at: $DEVBOX_UTILS" >&2
  exit 1
fi
# shellcheck disable=SC1090
source "$DEVBOX_UTILS"

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

Behavior:
  - Installs nvm from https://github.com/nvm-sh/nvm into ~/.nvm by default.
  - Configures ~/.zshrc and ~/.bashrc with a managed nvm initialization block.
  - Existing nvm installs are reused and updated when they are git checkouts.

Options:
  -h, --help             Show this help message
  -u, --uninstall        Remove nvm and the managed shell initialization block
  --version <TAG>        Install a specific nvm tag, for example v0.40.3
  --install-lts          Install the latest LTS Node.js and set it as default
  --nvm-dir <DIR>        Install directory (default: ~/.nvm)

Examples:
  $(basename "$0")
  $(basename "$0") --install-lts
  $(basename "$0") --version v0.40.3
  $(basename "$0") --uninstall
EOF
  exit 0
}

install_missing_deps() {
  local missing=()

  command -v git >/dev/null 2>&1 || missing+=(git)
  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    missing+=(curl)
  fi

  if [[ "${#missing[@]}" -eq 0 ]]; then
    return 0
  fi

  local package_manager
  package_manager="$(detect_package_manager)"

  info "Installing nvm prerequisites: ${missing[*]}"
  case "$package_manager" in
  brew)
    brew install "${missing[@]}"
    ;;
  apt-get)
    sudo apt-get update
    sudo apt-get install -y "${missing[@]}" ca-certificates
    ;;
  dnf)
    sudo dnf install -y "${missing[@]}" ca-certificates
    ;;
  yum)
    sudo yum install -y "${missing[@]}" ca-certificates
    ;;
  *)
    error "Missing required command(s): ${missing[*]}. Install them first and rerun this script."
    exit 1
    ;;
  esac
}

checkout_nvm_version() {
  local target_version

  if [[ -n "$NVM_VERSION" ]]; then
    target_version="$NVM_VERSION"
  else
    git -C "$NVM_DIR" fetch --tags --force origin
    target_version="$(git -C "$NVM_DIR" tag -l 'v[0-9]*' --sort=-v:refname | head -n 1)"
  fi

  if [[ -z "$target_version" ]]; then
    warning "No nvm release tag found; leaving checkout on the current branch."
    return 0
  fi

  info "Checking out nvm $target_version"
  git -C "$NVM_DIR" checkout "$target_version"
}

install_nvm() {
  install_missing_deps

  if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    success "nvm is already installed at $NVM_DIR"
    if [[ -d "$NVM_DIR/.git" ]]; then
      info "Updating existing nvm git checkout..."
      git -C "$NVM_DIR" fetch --tags --force origin
      checkout_nvm_version
    fi
    return 0
  fi

  if [[ -e "$NVM_DIR" ]]; then
    error "$NVM_DIR exists but does not contain nvm.sh. Move or remove it before rerunning."
    exit 1
  fi

  info "Cloning nvm into $NVM_DIR"
  git clone https://github.com/nvm-sh/nvm.git "$NVM_DIR"
  checkout_nvm_version
}

configure_nvm_rc() {
  local rc_file="$1"
  local configured_nvm_dir
  local content

  if [[ "$NVM_DIR" == "$HOME/.nvm" ]]; then
    configured_nvm_dir='${HOME}/.nvm'
  else
    configured_nvm_dir="$NVM_DIR"
  fi

  content=$(cat <<EOF
export NVM_DIR="$configured_nvm_dir"
[ -s "\$NVM_DIR/nvm.sh" ] && \. "\$NVM_DIR/nvm.sh"
[ -s "\$NVM_DIR/bash_completion" ] && \. "\$NVM_DIR/bash_completion"
EOF
  )

  configure_rc_block \
    "$rc_file" \
    "# >>> nvm initialize >>>" \
    "# <<< nvm initialize <<<" \
    "$content"
}

install_lts_node() {
  # shellcheck disable=SC1091
  . "$NVM_DIR/nvm.sh"
  info "Installing latest LTS Node.js via nvm..."
  nvm install --lts
  nvm alias default 'lts/*'
}

install() {
  install_nvm

  info "Configuring ~/.zshrc"
  configure_nvm_rc "$HOME/.zshrc"

  info "Configuring ~/.bashrc"
  configure_nvm_rc "$HOME/.bashrc"

  if [[ "$INSTALL_LTS" -eq 1 ]]; then
    install_lts_node
  fi

  success "nvm installation and shell configuration complete. Open a new shell or run: source ~/.zshrc"
}

uninstall() {
  local removed_any=0

  for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
    if [[ -f "$rc" ]] && grep -q "# >>> nvm initialize >>>" "$rc"; then
      info "Removing nvm initialization from $rc"
      remove_rc_block \
        "$rc" \
        "# >>> nvm initialize >>>" \
        "# <<< nvm initialize <<<"
      removed_any=1
    fi
  done

  if [[ -d "$NVM_DIR" ]]; then
    info "Removing $NVM_DIR"
    rm -rf "$NVM_DIR"
    removed_any=1
  fi

  if [[ "$removed_any" -eq 1 ]]; then
    success "nvm uninstalled. Open a new shell to clear loaded shell functions."
  else
    warning "nvm is not installed or no managed nvm block was found"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
    usage
    ;;
  -u | --uninstall)
    ACTION="uninstall"
    shift
    ;;
  --version)
    if [[ -z "${2:-}" ]]; then
      error "--version requires a tag, for example v0.40.3"
      exit 1
    fi
    NVM_VERSION="$2"
    shift 2
    ;;
  --install-lts)
    INSTALL_LTS=1
    shift
    ;;
  --nvm-dir)
    if [[ -z "${2:-}" ]]; then
      error "--nvm-dir requires a directory"
      exit 1
    fi
    NVM_DIR="$2"
    shift 2
    ;;
  *)
    error "Unknown option: $1"
    usage
    ;;
  esac
done

if [[ "$ACTION" == "uninstall" ]]; then
  uninstall
else
  install
fi
