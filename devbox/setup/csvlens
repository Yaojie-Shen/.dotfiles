#!/usr/bin/env bash

set -Eeuo pipefail

CSVLENS_VERSION="0.15.1"
CSVLENS_BIN=""

source "${BASH_SOURCE%/*}/../libexec/devbox-utils"

csvlens_default_url() {
  local os arch target
  os="$(uname -s)"
  arch="$(uname -m)"

  case "$arch" in
  arm64 | aarch64)
    arch="aarch64"
    ;;
  x86_64 | amd64)
    arch="x86_64"
    ;;
  *)
    error "Unsupported architecture: $arch (use --url to specify a custom download URL)"
    return 1
    ;;
  esac

  case "$os" in
  Darwin)
    target="apple-darwin"
    ;;
  Linux)
    target="unknown-linux-gnu"
    ;;
  *)
    error "Unsupported OS: $os (use --url to specify a custom download URL)"
    return 1
    ;;
  esac

  printf '%s\n' "https://github.com/YS-L/csvlens/releases/download/v${CSVLENS_VERSION}/csvlens-${arch}-${target}.tar.xz"
}

usage() {
  cat <<EOF
Usage: $(basename "$0") [options] [URL]

Behavior:
  - If Homebrew is available, prefer installing/uninstalling via brew.
  - If Homebrew install fails (or brew is unavailable), falls back to direct binary download.
  - Uninstall also removes legacy standalone installs at /usr/local/bin/csvlens (regular file only).
  - Standalone download URL is auto-selected based on OS/arch when not specified.

Options:
  -u, --uninstall    Uninstall csvlens
  -h, --help         Show this help message
  --url <URL>        Specify custom csvlens download URL

Arguments:
  URL                Alternative way to specify custom download URL
EOF
  exit 0
}

uninstall() {
  local removed_any=0

  if command -v brew >/dev/null 2>&1; then
    if brew list --versions csvlens >/dev/null 2>&1; then
      info "Uninstalling csvlens via Homebrew..."
      brew uninstall csvlens
      removed_any=1
    fi
  fi

  # Backward-compatible cleanup: older devbox versions may have installed a standalone binary here.
  # Keep this lightweight & safe: only remove the legacy file if it is a regular file.
  # If it's a symlink (possibly managed by Homebrew or user), skip removal.
  if [ -f /usr/local/bin/csvlens ]; then
    info "Removing legacy standalone /usr/local/bin/csvlens..."
    sudo rm -f /usr/local/bin/csvlens
    removed_any=1
  elif [ -L /usr/local/bin/csvlens ]; then
    info "Skipping /usr/local/bin/csvlens (symlink)"
  fi

  if [[ "$removed_any" -eq 1 ]]; then
    success "csvlens uninstalled successfully!"
  else
    warning "csvlens is not installed (neither Homebrew nor /usr/local/bin)"
    error "Nothing to remove"
  fi
}

install() {
  # If csvlens is already installed (any method), do nothing.
  if command -v brew >/dev/null 2>&1; then
    if brew list --versions csvlens >/dev/null 2>&1; then
      local brew_prefix brew_bin resolved
      brew_prefix="$(brew --prefix 2>/dev/null || true)"
      brew_bin="${brew_prefix%/}/bin/csvlens"
      resolved="$(command -v csvlens 2>/dev/null || true)"
      if [[ -n "$resolved" && -n "$brew_bin" && "$resolved" != "$brew_bin" ]]; then
        warning "Multiple csvlens detected: PATH resolves to $resolved (Homebrew is $brew_bin)"
      fi
      success "csvlens is already installed via Homebrew"
      return 0
    fi
  fi

  local existing
  existing="$(command -v csvlens 2>/dev/null || true)"
  if [[ -n "$existing" ]]; then
    success "csvlens is already installed: $existing"
    return 0
  fi

  # Prefer Homebrew when available. Still supports direct binary install as fallback.
  if command -v brew >/dev/null 2>&1; then
    info "Installing csvlens via Homebrew..."
    if brew install csvlens; then
      success "csvlens installed successfully via Homebrew!"
      return 0
    fi

    warning "Homebrew install failed; falling back to direct download install"
  fi

  # Select standalone URL based on OS/arch when user didn't specify one.
  if [[ -z "${CSVLENS_BIN:-}" ]]; then
    CSVLENS_BIN="$(csvlens_default_url)"
  fi

  local tmp_dir
  tmp_dir=$(mktemp -d)

  info "Downloading csvlens from $CSVLENS_BIN -> $tmp_dir..."
  curl -L --progress-bar "$CSVLENS_BIN" -o "$tmp_dir/csvlens.tar.xz" -f

  info "Extracting csvlens..."
  tar -xf "$tmp_dir/csvlens.tar.xz" -C "$tmp_dir"

  if [[ ! -f "$tmp_dir/csvlens" ]]; then
    error "Failed to locate csvlens binary in the archive"
    error "Please specify a custom URL via --url"
    rm -rf "$tmp_dir"
    return 1
  fi

  chmod +x "$tmp_dir/csvlens"

  info "Installing csvlens to /usr/local/bin..."
  sudo mv "$tmp_dir/csvlens" /usr/local/bin/csvlens

  printf "\n"
  /usr/local/bin/csvlens --help || true
  printf "\n"

  rm -rf "$tmp_dir"

  success "csvlens installed successfully!"
}

# Parse options
ACTION="install"

while [[ $# -gt 0 ]]; do
  case $1 in
  -u | --uninstall)
    ACTION="uninstall"
    shift
    ;;
  -h | --help)
    usage
    ;;
  --url)
    CSVLENS_BIN="$2"
    shift 2
    ;;
  *)
    if [[ $1 != -* ]]; then
      CSVLENS_BIN="$1"
      shift
    else
      error "Unknown option: $1"
      usage
    fi
    ;;
  esac
done

if [[ "$ACTION" == "uninstall" ]]; then
  uninstall
else
  install
fi

