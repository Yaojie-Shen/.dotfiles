#!/usr/bin/env bash

set -Eeuo pipefail

CHATGPT_CLI_RELEASE_BASE="https://github.com/kardolus/chatgpt-cli/releases/latest/download"
CHATGPT_CLI_BIN=""
# Parse options
ACTION="install"

source "${BASH_SOURCE%/*}/../libexec/devbox-utils"

usage() {
  cat <<EOF
Usage: $(basename "$0") [options] [URL]

Options:
  -u, --uninstall    Uninstall chatgpt-cli
  -h, --help         Show this help message
  --url <URL>        Specify custom chatgpt-cli download URL

Arguments:
  URL                Alternative way to specify custom download URL
EOF
  exit 0
}

install_from_url() {
  # Download prebuilt binary from the given URL and install it to /usr/local/bin/chatgpt
  local url="$1"
  local tmp_dir
  tmp_dir=$(mktemp -d)

  info "Downloading chatgpt-cli from $url -> $tmp_dir..."
  curl -L --progress-bar "$url" -o "$tmp_dir/chatgpt" -f
  chmod +x "$tmp_dir/chatgpt"
  info "Installing chatgpt-cli to /usr/local/bin..."
  sudo mv "$tmp_dir/chatgpt" /usr/local/bin/chatgpt

  rm -rf "$tmp_dir"
}

install() {
  # Check if chatgpt-cli is already installed
  if command -v chatgpt &>/dev/null; then
    error "chatgpt-cli is already installed"
    exit 0
  fi

  local os arch
  os=$(uname -s)
  arch=$(uname -m)

  if [[ "$os" == "Darwin" ]]; then
    # On macOS, prefer installing via Homebrew
    if ! command -v brew &>/dev/null; then
      error "Homebrew is not installed; please install Homebrew first"
      exit 1
    fi

    info "Installing chatgpt-cli via Homebrew..."
    brew install chatgpt-cli
  else
    # On non-macOS systems, choose the correct prebuilt binary based on OS and architecture
    if [[ -z "${CHATGPT_CLI_BIN:-}" ]]; then
      case "$os" in
      Linux)
        case "$arch" in
        x86_64 | amd64)
          CHATGPT_CLI_BIN="${CHATGPT_CLI_RELEASE_BASE}/chatgpt-linux-amd64"
          ;;
        arm64 | aarch64)
          CHATGPT_CLI_BIN="${CHATGPT_CLI_RELEASE_BASE}/chatgpt-linux-arm64"
          ;;
        i386 | i686)
          CHATGPT_CLI_BIN="${CHATGPT_CLI_RELEASE_BASE}/chatgpt-linux-386"
          ;;
        *)
          error "Unsupported Linux architecture: $arch. Please use --url to specify a custom binary URL."
          exit 1
          ;;
        esac
        ;;
      FreeBSD)
        case "$arch" in
        x86_64 | amd64)
          CHATGPT_CLI_BIN="${CHATGPT_CLI_RELEASE_BASE}/chatgpt-freebsd-amd64"
          ;;
        arm64 | aarch64)
          CHATGPT_CLI_BIN="${CHATGPT_CLI_RELEASE_BASE}/chatgpt-freebsd-arm64"
          ;;
        *)
          error "Unsupported FreeBSD architecture: $arch. Please use --url to specify a custom binary URL."
          exit 1
          ;;
        esac
        ;;
      *)
        error "Unsupported OS: $os. Please use --url to specify a custom binary URL."
        exit 1
        ;;
      esac
    fi

    install_from_url "$CHATGPT_CLI_BIN"
  fi

  printf "\n"
  chatgpt --help || true
  printf "\n"

  success "chatgpt-cli installed successfully!"
}

uninstall() {
  # On macOS, uninstall via Homebrew; otherwise remove the binary directly
  if [[ "$(uname -s)" == "Darwin" ]]; then
    if ! command -v brew &>/dev/null; then
      error "Homebrew is not installed; cannot uninstall chatgpt-cli via brew"
      exit 1
    fi

    if brew list --formula chatgpt-cli &>/dev/null; then
      info "Uninstalling chatgpt-cli via Homebrew..."
      brew uninstall chatgpt-cli
      success "chatgpt-cli uninstalled successfully via Homebrew!"
    else
      warning "chatgpt-cli is not installed via Homebrew"
      error "Nothing to remove"
    fi
  else
    if [ -f /usr/local/bin/chatgpt ]; then
      info "Uninstalling chatgpt-cli..."
      sudo rm /usr/local/bin/chatgpt
      success "chatgpt-cli uninstalled successfully!"
    else
      warning "chatgpt-cli is not installed at /usr/local/bin/chatgpt"
      error "Nothing to remove"
    fi
  fi
}

while [[ $# -gt 0 ]]; do
  case $1 in
  -u | --uninstall)
    ACTION="uninstall"
    shift
    ;;
  -h | --help)
    usage
    ;;
  --url)
    CHATGPT_CLI_BIN="$2"
    shift 2
    ;;
  *)
    if [[ $1 != -* ]]; then
      CHATGPT_CLI_BIN="$1"
      shift
    else
      error "Unknown option: $1"
      usage
    fi
    ;;
  esac
done

if [[ "$ACTION" == "uninstall" ]]; then
  uninstall
else
  install
fi
