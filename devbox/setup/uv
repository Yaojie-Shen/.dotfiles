#!/usr/bin/env bash

set -Eeuo pipefail

UV_INSTALL_BASE="https://astral.sh/uv"
UV_INSTALL_SCRIPT=""
UV_VERSION=""

ACTION="install"

source "${BASH_SOURCE%/*}/../libexec/devbox-utils"

usage() {
  cat <<EOF
Usage: 
  $(basename "$0") [options]

Options:
  -u, --uninstall        Uninstall uv
  -h, --help             Show this help message
  --version <VERSION>    Install a specific uv version (standalone installer)
  --url <URL>            Use a custom installer script URL (non-macOS only)

Behavior:
  - On macOS, uv is installed and uninstalled exclusively via Homebrew.
  - On Linux, uv is installed via the official standalone installer script.

Examples:
  # Install latest uv (macOS via Homebrew, Linux via installer)
  $(basename "$0")

  # Install a specific uv version on Linux
  $(basename "$0") --version 0.10.9

  # Uninstall uv
  $(basename "$0") --uninstall
EOF
  exit 0
}

install_standalone() {
  # Install uv using the official standalone installer on non-macOS systems.
  local script_url

  if [[ -n "${UV_INSTALL_SCRIPT:-}" ]]; then
    script_url="$UV_INSTALL_SCRIPT"
  elif [[ -n "${UV_VERSION:-}" ]]; then
    script_url="${UV_INSTALL_BASE}/${UV_VERSION}/install.sh"
  else
    script_url="${UV_INSTALL_BASE}/install.sh"
  fi

  info "Installing uv via standalone installer from $script_url..."

  if command -v curl &>/dev/null; then
    curl -LsSf "$script_url" | sh
  elif command -v wget &>/dev/null; then
    wget -qO- "$script_url" | sh
  else
    error "Neither curl nor wget is available; cannot run uv installer"
    exit 1
  fi
}

install() {
  # Check if uv is already installed
  if command -v uv &>/dev/null; then
    error "uv is already installed"
    exit 0
  fi

  local os
  os=$(uname -s)

  if [[ "$os" == "Darwin" ]]; then
    # On macOS, only allow installation via Homebrew
    if ! command -v brew &>/dev/null; then
      error "Homebrew is not installed; please install Homebrew first"
      exit 1
    fi

    info "Installing uv via Homebrew..."
    brew install uv
  elif [[ "$os" == "Linux" ]]; then
    install_standalone
  else
    error "Unsupported OS: $os. Please see https://docs.astral.sh/uv/getting-started/installation/ for manual installation instructions."
    exit 1
  fi

  printf "\n"
  uv --version || true
  printf "\n"

  success "uv installed successfully!"
}

uninstall() {
  # Uninstall uv using the corresponding method per platform.
  local os
  os=$(uname -s)

  if [[ "$os" == "Darwin" ]]; then
    # On macOS, only allow uninstall via Homebrew
    if ! command -v brew &>/dev/null; then
      error "Homebrew is not installed; cannot uninstall uv via brew"
      exit 1
    fi

    if brew list --formula uv &>/dev/null; then
      info "Uninstalling uv via Homebrew..."
      brew uninstall uv
      success "uv uninstalled successfully via Homebrew!"
    else
      warning "uv is not installed via Homebrew"
      error "Nothing to remove"
    fi
  elif [[ "$os" == "Linux" ]]; then
    # On Linux, follow the official guidance: clean cache and remove binaries.
    if command -v uv &>/dev/null; then
      info "Cleaning uv cache (uv cache clean)..."
      if ! uv cache clean; then
        warning "Failed to clean uv cache; continuing with binary removal"
      fi
    fi

    local bin_dir
    bin_dir="${HOME}/.local/bin"
    local removed_any=false

    for bin in uv uvx; do
      if [[ -f "$bin_dir/$bin" ]]; then
        info "Removing $bin_dir/$bin..."
        rm "$bin_dir/$bin"
        removed_any=true
      fi
    done

    if [[ "$removed_any" == false ]]; then
      warning "No uv binaries found in $bin_dir"
      error "Nothing to remove"
    else
      success "uv uninstalled successfully!"
    fi
  else
    error "Unsupported OS: $os. Please uninstall uv manually."
    exit 1
  fi
}

while [[ $# -gt 0 ]]; do
  case $1 in
  -u | --uninstall)
    ACTION="uninstall"
    shift
    ;;
  -h | --help)
    usage
    ;;
  --version)
    UV_VERSION="$2"
    shift 2
    ;;
  --url)
    UV_INSTALL_SCRIPT="$2"
    shift 2
    ;;
  *)
    error "Unknown option: $1"
    usage
    ;;
  esac
done

if [[ "$ACTION" == "uninstall" ]]; then
  uninstall
else
  install
fi

