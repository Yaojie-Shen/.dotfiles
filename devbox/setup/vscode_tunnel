#!/usr/bin/env bash

set -Eeuo pipefail

ACTION="install"
TUNNEL_NAME=""
PROVIDER="github"
BACKGROUND=0
LOGIN_MODE="auto"

INSTALL_DIR="${HOME}/.local/bin"
BIN_NAME="code-tunnel"

OS_OVERRIDE=""
URL_OVERRIDE=""
INSECURE=0

DEVBOX_UTILS="${DEVBOX_UTILS:-${DEVBOX_ROOT:-${HOME}/.devbox}/libexec/devbox-utils}"
if [[ ! -f "$DEVBOX_UTILS" ]]; then
  echo "Error: devbox-utils not found at: $DEVBOX_UTILS" >&2
  exit 1
fi

# shellcheck disable=SC1090
source "$DEVBOX_UTILS"

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

Behavior:
  - Downloads VS Code CLI tarball (stable) and installs it to a local bin.
  - Reuses an existing VS Code tunnel login when available.
  - Runs interactive 'code tunnel user login' only when login is needed.
  - Starts the tunnel.
  - Stops a running tunnel when requested.

Options:
  -h, --help                 Show this help message
  -u, --uninstall            Remove installed VS Code CLI binary (does not revoke login)
  -s, --stop                 Stop a running VS Code tunnel on this machine
  -b, --background           Start tunnel in background after login is confirmed
  -n, --name <NAME>          Tunnel name (default: hostname)
  -p, --provider <PROVIDER>  Login provider (default: github)
  --force-login, --login     Always run interactive login before starting tunnel
  --skip-login               Start tunnel without checking or prompting for login
  --install-dir <DIR>        Install directory (default: ~/.local/bin)
  --bin-name <NAME>          Installed binary name (default: code-tunnel)
  --os <OS>                  VS Code CLI 'os' param override (e.g. cli-linux-x64)
  --url <URL>                Full download URL override
  -k, --insecure             Pass -k to curl (skip TLS verify)
EOF
  exit 0
}

detect_vscode_cli_os() {
  local os arch
  os="$(uname -s)"
  arch="$(uname -m)"

  case "$arch" in
  x86_64 | amd64) arch="x64" ;;
  arm64 | aarch64) arch="arm64" ;;
  *)
    error "Unsupported architecture: $arch (use --os/--url to override)"
    return 1
    ;;
  esac

  case "$os" in
  Darwin) printf 'cli-darwin-%s\n' "$arch" ;;
  Linux)
    printf 'cli-linux-%s\n' "$arch"
    ;;
  *)
    error "Unsupported OS: $os (use --os/--url to override)"
    return 1
    ;;
  esac
}

default_download_url() {
  local os_param
  os_param="${OS_OVERRIDE:-}"
  if [[ -z "$os_param" ]]; then
    os_param="$(detect_vscode_cli_os)"
  fi

  printf '%s\n' "https://update.code.visualstudio.com/latest/${os_param}/stable"
}

installed_bin_path() {
  printf '%s\n' "${INSTALL_DIR%/}/${BIN_NAME}"
}

tunnel_name() {
  if [[ -n "$TUNNEL_NAME" ]]; then
    printf '%s\n' "$TUNNEL_NAME"
  else
    hostname -s 2>/dev/null || hostname 2>/dev/null || echo "vscode-tunnel"
  fi
}

require_value() {
  local option="${1:-}"
  local value="${2:-}"

  if [[ -z "$value" || "$value" == -* ]]; then
    error "Missing value for $option"
    return 1
  fi
}

ensure_installed() {
  local bin_path url tmp_dir tarball code_path curl_insecure
  bin_path="$(installed_bin_path)"

  if [[ -x "$bin_path" ]]; then
    success "VS Code CLI is already installed: $bin_path"
    return 0
  fi

  mkdir -p "$INSTALL_DIR"

  url="${URL_OVERRIDE:-}"
  if [[ -z "$url" ]]; then
    url="$(default_download_url)"
  fi

  tmp_dir="$(mktemp -d)"
  tarball="$tmp_dir/vscode_cli.tar.gz"
  curl_insecure=()
  if [[ "$INSECURE" -eq 1 ]]; then
    curl_insecure=(-k)
  fi

  info "Downloading VS Code CLI from $url -> $tarball..."
  curl -L --progress-bar -f "${curl_insecure[@]}" --output "$tarball" "$url"

  info "Extracting VS Code CLI..."
  tar -xzf "$tarball" -C "$tmp_dir"

  code_path=""
  if [[ -f "$tmp_dir/code" ]]; then
    code_path="$tmp_dir/code"
  else
    shopt -s nullglob
    for p in "$tmp_dir"/*/code; do
      if [[ -f "$p" ]]; then
        code_path="$p"
        break
      fi
    done
    shopt -u nullglob
  fi

  if [[ -z "$code_path" ]]; then
    rm -rf "$tmp_dir"
    error "Failed to locate 'code' binary in extracted archive"
    return 1
  fi

  chmod +x "$code_path"
  info "Installing VS Code CLI to $bin_path..."
  mv -f "$code_path" "$bin_path"

  rm -rf "$tmp_dir"
  success "VS Code CLI installed successfully: $bin_path"
}

ensure_cli_executable() {
  local bin_path
  bin_path="$(installed_bin_path)"

  if [[ ! -x "$bin_path" ]]; then
    error "VS Code CLI is not installed or not executable: $bin_path"
    return 1
  fi
}

uninstall() {
  local bin_path
  bin_path="$(installed_bin_path)"

  if [[ -f "$bin_path" ]]; then
    info "Removing $bin_path..."
    rm -f "$bin_path"
    success "VS Code CLI uninstalled: $bin_path"
  else
    warning "VS Code CLI is not installed at $bin_path"
    error "Nothing to remove"
  fi
}

is_logged_in() {
  local bin_path
  bin_path="$(installed_bin_path)"

  "$bin_path" tunnel user show >/dev/null 2>&1
}

ensure_logged_in() {
  local bin_path
  bin_path="$(installed_bin_path)"

  case "$LOGIN_MODE" in
  skip)
    info "Skipping VS Code tunnel login check."
    return 0
    ;;
  force)
    info "Running: $bin_path tunnel user login --provider $PROVIDER"
    "$bin_path" tunnel user login --provider "$PROVIDER"
    return 0
    ;;
  auto)
    if is_logged_in; then
      success "VS Code tunnel user is already logged in."
      return 0
    fi

    info "No active VS Code tunnel login found; starting interactive login..."
    "$bin_path" tunnel user login --provider "$PROVIDER"
    ;;
  *)
    error "Invalid login mode: $LOGIN_MODE"
    return 1
    ;;
  esac
}

stop_tunnel() {
  local bin_path kill_output status_output

  bin_path="$(installed_bin_path)"
  ensure_cli_executable

  status_output="$("$bin_path" tunnel status 2>/dev/null || true)"
  if [[ "$status_output" == *'"tunnel":null'* ]]; then
    warning "No running VS Code tunnel found."
    return 0
  fi

  info "Running: $bin_path tunnel kill"
  if kill_output="$("$bin_path" tunnel kill 2>&1)"; then
    [[ -n "$kill_output" ]] && printf '%s\n' "$kill_output"
    success "VS Code tunnel stopped."
    return 0
  fi

  if [[ "$kill_output" == *"no tunnel process is currently running"* ]]; then
    warning "No running VS Code tunnel found."
    return 0
  fi

  [[ -n "$kill_output" ]] && printf '%s\n' "$kill_output" >&2
  return 1
}

start_tunnel() {
  local bin_path name
  bin_path="$(installed_bin_path)"

  name="$(tunnel_name)"

  info "Starting tunnel: $bin_path tunnel --accept-server-license-terms --name $name"
  "$bin_path" tunnel --accept-server-license-terms --name "$name"
}

run_login_and_tunnel() {
  ensure_cli_executable
  ensure_logged_in
  start_tunnel
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
    usage
    ;;
  -u | --uninstall)
    ACTION="uninstall"
    shift
    ;;
  -s | --stop)
    ACTION="stop"
    shift
    ;;
  -b | --background)
    BACKGROUND=1
    shift
    ;;
  -n | --name)
    require_value "$1" "${2:-}"
    TUNNEL_NAME="$2"
    shift 2
    ;;
  -p | --provider)
    require_value "$1" "${2:-}"
    PROVIDER="$2"
    shift 2
    ;;
  --force-login | --login)
    LOGIN_MODE="force"
    shift
    ;;
  --skip-login)
    LOGIN_MODE="skip"
    shift
    ;;
  --install-dir)
    require_value "$1" "${2:-}"
    INSTALL_DIR="$2"
    shift 2
    ;;
  --bin-name)
    require_value "$1" "${2:-}"
    BIN_NAME="$2"
    shift 2
    ;;
  --os)
    require_value "$1" "${2:-}"
    OS_OVERRIDE="$2"
    shift 2
    ;;
  --url)
    require_value "$1" "${2:-}"
    URL_OVERRIDE="$2"
    shift 2
    ;;
  -k | --insecure)
    INSECURE=1
    shift
    ;;
  *)
    error "Unknown option: $1"
    usage
    ;;
  esac
done

if [[ "$ACTION" == "uninstall" ]]; then
  uninstall
  exit 0
fi

if [[ "$ACTION" == "stop" ]]; then
  stop_tunnel
  exit 0
fi

ensure_installed

if [[ "$BACKGROUND" -eq 1 ]]; then
  ensure_cli_executable
  ensure_logged_in
  info "Starting tunnel in background (stdout/stderr remain on this terminal)..."
  # Avoid accidental terminal reads in background. Output stays attached to the current terminal.
  (start_tunnel) </dev/null &
  success "Started background job (pid: $!)"
else
  run_login_and_tunnel
fi
