#!/usr/bin/env bash

set -e

CONFIG="install.conf.yaml"
DOTBOT_DIR="dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Dotbot
echo -e "\033[34m==> Updating Dotbot\033[0m" >&2
cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

# Pull latest dotfile & custom
echo -e "\033[34m==> Updating main project...\033[0m"
(set +e && git -C "$BASEDIR" pull && echo -e "\033[32m✔ Main project updated\033[0m")
CUSTOM_DIR="$BASEDIR/persistent/custom"
if [ -d "$CUSTOM_DIR" ]; then
  echo -e "\033[34m==> Updating custom project...\033[0m"
  if git -C "$CUSTOM_DIR" pull; then
    echo -e "\033[32m✔ Custom project updated\033[0m"
  else
    echo -e "\033[33m⚠ Custom project pull failed (ignored)\033[0m"
  fi
else
  echo -e "\033[33m⚠ Custom project not found, skipping\033[0m"
fi

echo -e "\033[32m==> Running dotbot config: ${CONFIG}\033[0m"
(set +e && "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}" || true)

# Optional private/custom dotbot config (kept outside this repo).
# Convention:
# - persistent/install.conf.yaml, or
# - persistent/custom/install.conf.yaml (the `custom` folder can be a git repository)
if [[ -f "${BASEDIR}/persistent/install.conf.yaml" ]]; then
  CUSTOM_CONFIG="${BASEDIR}/persistent/install.conf.yaml"
elif [[ -f "${BASEDIR}/persistent/custom/install.conf.yaml" ]]; then
  CUSTOM_CONFIG="${BASEDIR}/persistent/custom/install.conf.yaml"
fi

if [[ -n "${CUSTOM_CONFIG}" ]]; then
  CUSTOM_DIR="${CUSTOM_CONFIG%/*}"
  echo -e "\033[32m==> Running custom dotbot config: ${CUSTOM_CONFIG}\033[0m" >&2
  (set +e && bash "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${CUSTOM_DIR}" -c "${CUSTOM_CONFIG}" "${@}" || true)
fi
